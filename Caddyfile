:8080 {
	root * /srv
	encode zstd gzip

	# Hashed static assets — cache for 1 year (hash changes on rebuild)
	@static {
		path /growthmap/*/out/_next/static/*
		path /growthmap/*/dist/assets/*
		path /growthmap/*/build/static/*
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# HTML — never cache (must always fetch latest asset references)
	@html {
		path *.html
		path /
	}
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	file_server
	try_files {path} {path}/ /index.html
}
