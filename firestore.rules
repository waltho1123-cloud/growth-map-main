rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only a signed-in user can read/write their own docs.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /apps/{doc=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
