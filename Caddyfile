:8080 {
	root * /srv
	encode zstd gzip

	# Hashed assets (JS/CSS/fonts) — cache for 1 year
	@hashed path_regexp \.[0-9a-f]{8,}\.(js|css|woff2?)$
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# HTML — never cache (must always fetch latest asset references)
	@html path *.html /
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	file_server
	try_files {path} {path}/ /index.html
}
